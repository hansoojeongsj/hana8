GET {{baseUrl}}/search?datetime=2026-03-05 09:16

### member-regist
POST {{baseUrl}}
Content-Type: application/json

{
  "nickname": "guest",
  "email": "guest@email.com",
  "passwd": "xxxxxxxx",
  "bloodType": "O",
  "isActive": true
}

### member-info
# Warn: Member #5 is not found!
GET {{baseUrl}}/2

### post-update
PUT {{baseUrl}}/4
Content-Type: application/json

{
  "id": 4,
  "nickname": "guestxx",
  "email": "guest@email.comxx",
  "passwd": "xxxxxxxx",
  "bloodType": "O",
  "isActive": false
}

### withdraw member
DELETE {{baseUrl}}/5

### 파일 업로드 http
#POST {{baseUrl}}/files/upload
POST {{baseUrl}}/files/secure/upload
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="file"; filename="test.jpeg"
Content-Type: image/jpeg

< /Users/hansoojeong/Downloads/test1.jpeg
--boundary–


### 다중 파일 업로드
POST {{baseUrl}}/files/upload/multiple
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="files"; filename="test1.jpg"
Content-Type: image/jpeg

< /Users/hansoojeong/Downloads/test3.jpg
--boundary
Content-Disposition: form-data; name="files"; filename="test2.jpg"
Content-Type: image/jpeg

< /Users/hansoojeong/Downloads/test2.png
--boundary--

### 파일 다운로드
GET {{baseUrl}}/files/download/1793435a-8e62-4281-92fe-e111bd1803fc.jpg

### 파일 다운로드 (secure)
GET {{baseUrl}}/files/download/thumb_1793435a-8e62-4281-92fe-e111bd1803fc.jpg?isSecure=true

### 파일 삭제
DELETE {{baseUrl}}/files/delete/1793435a-8e62-4281-92fe-e111bd1803fc.jpg

### POST 추가
POST {{baseUrl}}/1/images
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="files"; filename="test1.jpg"
Content-Type: image/jpeg

< /Users/jade/tmp/test1.jpg
--boundary
Content-Disposition: form-data; name="remarks"

첫번째 파일 설명
--boundary
Content-Disposition: form-data; name="files"; filename="test2.png"
Content-Type: image/png

< /Users/jade/tmp/test2.png
--boundary--
Content-Disposition: form-data; name="remarks"

두번째 파일 설명
--boundary--

